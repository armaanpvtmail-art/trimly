#######################################################################
# Trimly — Environment Variables
# Copy this file to `.env` (local) or `.env.production` (server) and fill
# in real values. NEVER commit a populated env file.
#######################################################################

# ----- Core -----
# Public base URL of the app (used for short links, OG tags, redirects)
NEXT_PUBLIC_APP_URL="https://trimly.app"
NEXT_PUBLIC_APP_NAME="Trimly"
NODE_ENV="production"

# ----- Database (PostgreSQL ONLY) -----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://trimly:trimly@localhost:5432/trimly?schema=public"

# ----- Redis (caching + rate limiting) -----
REDIS_URL="redis://localhost:6379"

# ----- NextAuth -----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://trimly.app"

# ----- Cashfree (PRODUCTION mode) -----
# Get these from https://merchant.cashfree.com  -> Developers -> API Keys
CASHFREE_ENV="PRODUCTION"          # PRODUCTION | SANDBOX
CASHFREE_APP_ID="your-production-app-id"
CASHFREE_SECRET_KEY="your-production-secret-key"
# Webhook signature secret (Cashfree -> Developers -> Webhooks). Used to verify
# x-webhook-signature on incoming payment notifications.
CASHFREE_WEBHOOK_SECRET="your-cashfree-webhook-secret"
# Cashfree API version pinned by the integration
CASHFREE_API_VERSION="2023-08-01"

# ----- Subscription plan -----
PLAN_PRICE_INR="90"
PLAN_NAME="Premium Monthly"
PLAN_DURATION_DAYS="30"
PLAN_CURRENCY="INR"

# ----- SMTP (email verification + password reset) -----
SMTP_HOST="smtp.yourprovider.com"
SMTP_PORT="587"
SMTP_SECURE="false"               # true for 465, false for 587
SMTP_USER="no-reply@trimly.app"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="Trimly <no-reply@trimly.app>"

# ----- Admin bootstrap (used by `npm run db:seed`) -----
ADMIN_EMAIL="admin@trimly.app"
ADMIN_PASSWORD="ChangeMe!2026"
ADMIN_NAME="Trimly Admin"

# ----- Uploads / themes -----
# Directory (relative to project root) where uploaded theme assets are stored.
THEME_UPLOAD_DIR="public/uploads/themes"
MAX_THEME_ZIP_MB="20"

# ----- Security -----
# Comma-separated list of trusted origins for CSRF / CORS allowance
TRUSTED_ORIGINS="https://trimly.app"
# Per-IP rate limit for redirect + auth endpoints (requests per window)
RATE_LIMIT_MAX="60"
RATE_LIMIT_WINDOW_SECONDS="60"
