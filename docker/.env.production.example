# Example production environment variables for docker-compose

# App config
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXTAUTH_SECRET=replace-with-strong-secret

# Database
DATABASE_URL=postgresql://trimly:replace-with-pg-password@postgres:5432/trimly
POSTGRES_PASSWORD=replace-with-pg-password

# Redis
REDIS_PASSWORD=replace-with-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# Cashfree
CASHFREE_ENV=PRODUCTION
CASHFREE_APP_ID=replace-with-cashfree-app-id
CASHFREE_SECRET_KEY=replace-with-cashfree-secret
CASHFREE_WEBHOOK_SECRET=replace-with-webhook-secret

# SMTP (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=no-reply@your-domain.com
